# App Presup — variables de entorno
# Copiá este archivo como .env.local y completá los valores

# ─── Supabase de esta app ────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<proyecto>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ─── SaaS central (suscripciones) ────────────────────────────────────────────
# URL y service-role key del proyecto Supabase central
CENTRAL_URL=https://<central>.supabase.co
CENTRAL_SERVICE_KEY=eyJ...

# ─── CORS (API serverless) ───────────────────────────────────────────────────
# Dominio de producción de la app (sin barra final)
APP_ORIGIN=https://app-presup.vercel.app

# ─── Observabilidad (opcional) ───────────────────────────────────────────────
# DSN de Sentry — dejar vacío para deshabilitar
VITE_SENTRY_DSN=
